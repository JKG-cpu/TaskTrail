    "hide-files.files": [
        ".gitignore",
        ".python-version",
        "LICENSE",
        "Task Trail.png",
        "uv.lock",
        "pyproject.toml",
        ".venv"
    ],
    "python-envs.defaultEnvManager": "ms-python.python:system"
}